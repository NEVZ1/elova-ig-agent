# Core
ENV=local
LOG_LEVEL=INFO
BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/elova_dm
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/elova_dm

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# LLM routing
LLM_PROVIDER=gemini
LLM_UNIFIED_MODE=true

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Instagram / Meta
IG_VERIFY_TOKEN=change-me
IG_PROVIDER=meta_graph
IG_PAGE_ACCESS_TOKEN=
IG_PAGE_ID=
IG_APP_SECRET=
IG_REQUIRE_SIGNATURE=true

# Business conversion routing
WHATSAPP_NUMBER=+90XXXXXXXXXX
BOOKING_URL=https://cal.com/your-handle/elova-consultation

# Admin
ADMIN_API_KEY=change-me
