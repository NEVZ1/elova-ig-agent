# Core
ENV=local
LOG_LEVEL=INFO
BASE_URL=http://localhost:8000

# Database
# Example only. Use your real provider connection string and keep it secret.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# Optional (leave blank to auto-derive from DATABASE_URL)
DATABASE_URL_SYNC=

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
# Optional (leave blank to use REDIS_URL)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LLM routing
LLM_PROVIDER=openai
LLM_UNIFIED_MODE=true

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Instagram / Meta
IG_VERIFY_TOKEN=
IG_PROVIDER=meta_graph
IG_PAGE_ACCESS_TOKEN=
IG_PAGE_ID=
# Instagram Business/Professional Account ID to send messages from.
# If blank, the app falls back to IG_PAGE_ID (may fail for Instagram messaging).
IG_SENDER_ID=
IG_APP_SECRET=
IG_REQUIRE_SIGNATURE=true

# Business conversion routing (optional)
WHATSAPP_NUMBER=
BOOKING_URL=

# Admin
ADMIN_API_KEY=
